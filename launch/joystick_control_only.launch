<launch>
  <!-- ================================================================
       Joystick Control Only (without eye serial connections)

       Use this when eye modules are already running via demo_dual.launch

       Features:
       - Right stick: NEXTAGE head (50% slower movement)
       - Left stick: Eye gaze control
       - Buttons: Eye expressions
       ================================================================ -->

  <!-- Parameters -->
  <arg name="joy_dev"         default="/dev/input/js0" />
  <arg name="max_angle"       default="0.523" />  <!-- 30 deg = 50% of original 60 deg -->
  <arg name="head_rate"       default="10.0" />
  <arg name="move_duration"   default="0.7" />    <!-- Slower movement (was 0.5) -->

  <!-- Eye movement parameters -->
  <arg name="left_edge"       default="30.0" />
  <arg name="right_edge"      default="-30.0" />
  <arg name="upper_edge"      default="-30.0" />
  <arg name="bottom_edge"     default="30.0" />

  <!-- ================================================================
       1. Joystick Node
       ================================================================ -->
  <node pkg="joy" type="joy_node" name="joy_node" output="screen">
    <param name="dev"             value="$(arg joy_dev)" />
    <param name="deadzone"        value="0.05" />
    <param name="autorepeat_rate" value="30" />
  </node>

  <!-- ================================================================
       2. NEXTAGE Head Control (Right Stick) - 50% slower
       ================================================================ -->
  <node pkg="robot_joy_control" type="joy_head_nextage.py" name="joy_head_nextage" output="screen">
    <param name="max_angle"      value="$(arg max_angle)" />
    <param name="axis_yaw"       value="3" />
    <param name="axis_pitch"     value="4" />
    <param name="snap_threshold" value="0.1" />
    <param name="move_duration"  value="$(arg move_duration)" />
    <param name="yaw_invert"     value="1.0" />
    <param name="pitch_invert"   value="-1.0" />
    <param name="rate"           value="$(arg head_rate)" />
  </node>

  <!-- ================================================================
       3. Eye Control (Left Stick) - Namespace version
       ================================================================ -->

  <!-- Right eye control -->
  <group ns="right">
    <node pkg="eye_display" type="joy_eye_status_namespace.py" name="joy_eye_status" output="screen">
      <param name="left_edge"   value="$(arg left_edge)" />
      <param name="right_edge"  value="$(arg right_edge)" />
      <param name="upper_edge"  value="$(arg upper_edge)" />
      <param name="bottom_edge" value="$(arg bottom_edge)" />
      <param name="duration"    value="0.02" />  <!-- 50Hz for faster response -->
    </node>
  </group>

  <!-- Left eye control -->
  <group ns="left">
    <node pkg="eye_display" type="joy_eye_status_namespace.py" name="joy_eye_status" output="screen">
      <param name="left_edge"   value="$(arg left_edge)" />
      <param name="right_edge"  value="$(arg right_edge)" />
      <param name="upper_edge"  value="$(arg upper_edge)" />
      <param name="bottom_edge" value="$(arg bottom_edge)" />
      <param name="duration"    value="0.02" />  <!-- 50Hz for faster response -->
    </node>
  </group>

</launch>