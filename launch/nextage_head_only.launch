<launch>
  <!-- ================================================================
       NEXTAGE Head Control Only

       Right stick controls robot head:
       - Horizontal (axis 3): Yaw (left/right)
       - Vertical (axis 4): Pitch (up/down)

       Settings:
       - 50% slower movement for safety
       - Pitch inverted for intuitive control
       ================================================================ -->

  <!-- Parameters - OPTIMIZED for fast response with safe speed -->
  <arg name="joy_dev"         default="/dev/input/js0" />
  <arg name="max_angle"       default="0.523" />  <!-- 30 deg = 50% of 60 deg (smooth & safe) -->
  <arg name="move_duration"   default="0.1" />    <!-- Fast response -->
  <arg name="rate"            default="30.0" />   <!-- 30Hz update rate -->

  <!-- Joystick Node -->
  <node pkg="joy" type="joy_node" name="joy_node" output="screen">
    <param name="dev"             value="$(arg joy_dev)" />
    <param name="deadzone"        value="0.05" />
    <param name="autorepeat_rate" value="30" />
  </node>

  <!-- NEXTAGE Head Control -->
  <node pkg="robot_joy_control" type="joy_head_nextage.py" name="joy_head_nextage" output="screen">
    <param name="max_angle"      value="$(arg max_angle)" />
    <param name="axis_yaw"       value="3" />        <!-- Right stick horizontal -->
    <param name="axis_pitch"     value="4" />        <!-- Right stick vertical -->
    <param name="snap_threshold" value="0.02" />      <!-- More sensitive -->
    <param name="move_duration"  value="$(arg move_duration)" />
    <!-- Direction control for observer perspective:
         yaw_invert=-1.0: Stick LEFT moves robot head to observer's LEFT (facing robot)
         pitch_invert=-1.0: Stick UP moves robot head UP -->
    <param name="yaw_invert"     value="-1.0" />      <!-- Inverted for observer perspective -->
    <param name="pitch_invert"   value="-1.0" />      <!-- Inverted for intuitive control -->
    <param name="rate"           value="$(arg rate)" />
  </node>

</launch>