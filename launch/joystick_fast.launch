<launch>
  <!-- ================================================================
       Fast Response Joystick Control

       - Direct event-based processing for eye modules (no timer delay)
       - Optimized for minimal latency
       ================================================================ -->

  <!-- Parameters -->
  <arg name="joy_dev"         default="/dev/input/js0" />
  <arg name="max_angle"       default="0.523" />  <!-- 30 deg = 50% speed -->
  <arg name="move_duration"   default="0.7" />    <!-- Slower robot head movement -->

  <!-- Eye movement ranges -->
  <arg name="left_edge"       default="30.0" />
  <arg name="right_edge"      default="-30.0" />
  <arg name="upper_edge"      default="-30.0" />
  <arg name="bottom_edge"     default="30.0" />

  <!-- ================================================================
       1. Joystick Node - Higher update rate
       ================================================================ -->
  <node pkg="joy" type="joy_node" name="joy_node" output="screen">
    <param name="dev"             value="$(arg joy_dev)" />
    <param name="deadzone"        value="0.02" />  <!-- Smaller deadzone -->
    <param name="autorepeat_rate" value="60" />    <!-- Faster update rate -->
  </node>

  <!-- ================================================================
       2. NEXTAGE Head Control (Right Stick)
       ================================================================ -->
  <node pkg="robot_joy_control" type="joy_head_nextage.py" name="joy_head_nextage" output="screen">
    <param name="max_angle"      value="$(arg max_angle)" />
    <param name="axis_yaw"       value="3" />
    <param name="axis_pitch"     value="4" />
    <param name="snap_threshold" value="0.1" />
    <param name="move_duration"  value="$(arg move_duration)" />
    <param name="yaw_invert"     value="1.0" />
    <param name="pitch_invert"   value="-1.0" />
    <param name="rate"           value="20.0" />  <!-- Faster rate -->
  </node>

  <!-- ================================================================
       3. Direct Eye Control (Left Stick) - Event-based for fast response
       ================================================================ -->

  <!-- Right eye - direct control -->
  <group ns="right">
    <node pkg="eye_display" type="joy_eye_status_direct.py" name="joy_eye_direct" output="screen">
      <param name="left_edge"      value="$(arg left_edge)" />
      <param name="right_edge"     value="$(arg right_edge)" />
      <param name="upper_edge"     value="$(arg upper_edge)" />
      <param name="bottom_edge"    value="$(arg bottom_edge)" />
      <param name="snap_threshold" value="0.05" />
    </node>
  </group>

  <!-- Left eye - direct control -->
  <group ns="left">
    <node pkg="eye_display" type="joy_eye_status_direct.py" name="joy_eye_direct" output="screen">
      <param name="left_edge"      value="$(arg left_edge)" />
      <param name="right_edge"     value="$(arg right_edge)" />
      <param name="upper_edge"     value="$(arg upper_edge)" />
      <param name="bottom_edge"    value="$(arg bottom_edge)" />
      <param name="snap_threshold" value="0.05" />
    </node>
  </group>

</launch>